# Required — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default model when Custom preset is selected with an empty model field.
# Also used as server fallback when no preset applies.
# Example: z-ai/glm-5.1
OPENROUTER_MODEL=

# Model for Enhance prompt and Adaptive scope JSON calls (must support JSON mode).
# Example: deepseek/deepseek-v4-flash
OPENROUTER_ENHANCE_MODEL=

# Optional — used for OpenRouter HTTP-Referer header (set to your Vercel URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
